rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      match /accounts/{accountId} {
        allow read, write: if signedIn() && request.auth.uid == uid;

        match /friends/{friendId} {
          allow read, delete: if signedIn() && request.auth.uid == uid;
          allow create, update: if signedIn() && request.auth.uid == uid
            && request.resource.data.friendCode is string
            && request.resource.data.friendCode.matches('^[a-zA-Z0-9]{6,12}$');
        }
      }

      match /reminderLog/{day} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    match /families/{familyId} {
      allow read, update, delete: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      match /friends/{friendId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberUids;
        allow write: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberUids
          && (request.method == 'delete' || (
            request.resource.data.friendCode is string &&
            request.resource.data.friendCode.matches('^[a-zA-Z0-9]{6,12}$')
          ));
      }
    }
  }
}
