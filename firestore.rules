// Les règles de sécurité de Firebase (Firestore Rules) : Ce sont elles qui définissent qui a le droit de lire et écrire dans votre base de données (déjà configurées dans votre fichier firestore.rules).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      match /accounts/{accountId} {
        allow read, write: if signedIn() && request.auth.uid == uid;

        match /friends/{friendId} {
          allow read, delete: if signedIn() && request.auth.uid == uid;
          allow create, update: if signedIn() && request.auth.uid == uid
            && request.resource.data.friendCode is string
            && request.resource.data.friendCode.matches('^[a-zA-Z0-9]{6,12}$');
        }
      }

      match /reminderLog/{day} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }
  }
}
